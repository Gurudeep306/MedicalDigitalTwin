# Optional Unreal stream, if you ever use Pixel Streaming again.
NEXT_PUBLIC_PIXEL_STREAMING_URL=

# Preferred no-install anatomy engine: publish BioDigital Human Viewer URLs
# and paste them here. The app chooses the right scene from the user's profile.
NEXT_PUBLIC_BIODIGITAL_VIEWER_URL=
NEXT_PUBLIC_BIODIGITAL_MALE_VIEWER_URL=
NEXT_PUBLIC_BIODIGITAL_FEMALE_VIEWER_URL=
NEXT_PUBLIC_BIODIGITAL_CHILD_VIEWER_URL=

# Optional medicine-specific scenes. Publish BioDigital treatment/condition
# widgets for each pathway and the app will swap to them during simulation.
NEXT_PUBLIC_BIODIGITAL_IBUPROFEN_VIEWER_URL=
NEXT_PUBLIC_BIODIGITAL_METFORMIN_VIEWER_URL=
NEXT_PUBLIC_BIODIGITAL_ATORVASTATIN_VIEWER_URL=
NEXT_PUBLIC_BIODIGITAL_ALBUTEROL_VIEWER_URL=
